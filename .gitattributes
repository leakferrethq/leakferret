* text=auto eol=lf

# Rust
*.rs        text eol=lf
Cargo.toml  text eol=lf
Cargo.lock  text eol=lf

# Config
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Shell scripts must be LF
*.sh        text eol=lf

# Windows-specific keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
